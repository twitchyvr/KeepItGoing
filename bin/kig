#!/bin/bash
# kig — control KeepItGoing from the command line.
#
# Usage:
#   kig                    show status: countdown to next fire + per-tab state
#   kig status             same as above
#   kig on | off           enable/disable KeepItGoing for THIS iTerm tab
#   kig pause              pause ALL firing globally until `kig resume`
#   kig resume             resume after pause
#   kig cancel             cancel ONLY the next scheduled fire (one-shot)
#   kig snooze <duration>  delay next fire by duration (e.g. 5m, 10min, 1h, 30s)
#   kig fire               fire immediately, bypassing cooldown (one-shot)
#   kig edit               open override-prompt.txt in $EDITOR — next fire uses this verbatim
#   kig preview            show what prompt the generator would produce right now (no fire)
#   kig model              show current classifier model
#   kig model <profile>    switch classifier profile (haiku|sonnet|opus|minimax-highspeed|minimax)
#   kig model list         list all profiles
#   kig unstuck            escalate the focused Claude tab's stuck session to Opus (or configured model)
#   kig unstuck --dry-run  show what context would be sent without actually calling Opus
#   kig budget             show today's Claude escalation budget (wall-clock time used)
#   kig budget set <dur>   set the daily escalation budget (e.g. 4h, 6h, 30m)
#   kig budget model <m>   set the escalation model (opus|sonnet|haiku)
#   kig escalations        tail the log of recent escalations and their outcomes
#   kig watch              live countdown display, refreshing every second
#   kig list               show every Claude tab's on/off state
#   kig log                tail the KIG log
#   kig help               show this help
#
# State files (in /tmp/claude-keepitgoing/):
#   pause.lock        present ⇒ globally paused
#   cancel-next.lock  present ⇒ skip ONE upcoming fire, then auto-clear
#   snooze-until.txt  contains epoch seconds ⇒ no firing before that time
#   fire-now.lock     present ⇒ fire immediately on next poll, auto-clear
#
# The AppleScript applet checks these at the top of each poll iteration.

set -euo pipefail

STATE_DIR="/tmp/claude-keepitgoing"
LOG_FILE="$STATE_DIR/app.log"
PAUSE_LOCK="$STATE_DIR/pause.lock"
CANCEL_LOCK="$STATE_DIR/cancel-next.lock"
SNOOZE_FILE="$STATE_DIR/snooze-until.txt"
FIRE_LOCK="$STATE_DIR/fire-now.lock"

mkdir -p "$STATE_DIR"

# Colors (only if stdout is a tty)
if [ -t 1 ]; then
  R=$'\033[0;31m'; G=$'\033[0;32m'; Y=$'\033[0;33m'; B=$'\033[0;34m'; D=$'\033[2m'; N=$'\033[0m'
else
  R=""; G=""; Y=""; B=""; D=""; N=""
fi

# Parse durations like "5m", "30s", "1h", "90", "10min" → seconds
parse_duration() {
  local d="$1"
  if [[ "$d" =~ ^([0-9]+)(s|sec|secs|second|seconds)?$ ]]; then
    echo "${BASH_REMATCH[1]}"
  elif [[ "$d" =~ ^([0-9]+)(m|min|mins|minute|minutes)$ ]]; then
    echo $((BASH_REMATCH[1] * 60))
  elif [[ "$d" =~ ^([0-9]+)(h|hr|hrs|hour|hours)$ ]]; then
    echo $((BASH_REMATCH[1] * 3600))
  else
    echo "kig: can't parse duration '$d' (try 30s, 5m, 1h)" >&2
    exit 1
  fi
}

# Format seconds as "Mm SSs" or "HHh MMm"
fmt_duration() {
  local s="$1"
  if [ "$s" -lt 60 ]; then printf '%ds' "$s"
  elif [ "$s" -lt 3600 ]; then printf '%dm %02ds' $((s / 60)) $((s % 60))
  else printf '%dh %02dm' $((s / 3600)) $(((s % 3600) / 60))
  fi
}

# Read last bailout/sent line from log → compute countdown
# Returns "ready|cooldown|sent" on stdout, plus details
compute_countdown() {
  if [ ! -f "$LOG_FILE" ]; then
    echo "nolog"
    return
  fi
  # Look at last ~5 lines for the most recent cooldown report OR send event
  local recent
  recent=$(tail -10 "$LOG_FILE" 2>/dev/null)
  # Match: "bailout cooldown | mode=X | cwd=Y | timeSince=N.N | required=M"
  # or:    "KeepItGoing] prompt sent | mode=X | ... idleDur=Ns"
  local last_line
  last_line=$(echo "$recent" | grep -E "bailout cooldown|prompt sent" | tail -1)
  if [ -z "$last_line" ]; then
    echo "unknown"
    return
  fi
  if echo "$last_line" | grep -q "prompt sent"; then
    # Just sent — figure out when, compute elapsed since
    local sent_ts
    sent_ts=$(echo "$last_line" | sed -n 's/^\[\([0-9: -]*\)\].*/\1/p')
    echo "sent|$sent_ts"
    return
  fi
  # bailout cooldown case
  local time_since required mode
  time_since=$(echo "$last_line" | sed -n 's/.*timeSince=\([0-9.]*\).*/\1/p')
  required=$(echo "$last_line" | sed -n 's/.*required=\([0-9.]*\).*/\1/p')
  mode=$(echo "$last_line" | sed -n 's/.*mode=\([a-z]*\).*/\1/p')
  if [ -z "$time_since" ] || [ -z "$required" ]; then
    echo "unknown"
    return
  fi
  local log_ts log_epoch now_epoch poll_elapsed
  log_ts=$(echo "$last_line" | sed -n 's/^\[\([0-9: -]*\)\].*/\1/p')
  log_epoch=$(date -j -f "%Y-%m-%d %H:%M:%S" "$log_ts" +%s 2>/dev/null || echo 0)
  now_epoch=$(date +%s)
  poll_elapsed=$((now_epoch - log_epoch))
  # remaining = required - (timeSince + elapsed-since-log)
  local time_since_int remaining
  time_since_int=${time_since%.*}
  remaining=$(awk "BEGIN { r = $required - ($time_since_int + $poll_elapsed); printf \"%d\", (r < 0 ? 0 : r) }")
  echo "cooldown|$remaining|$required|$mode"
}

# Check state file conditions
get_control_state() {
  if [ -f "$PAUSE_LOCK" ]; then echo "paused"; return; fi
  if [ -f "$FIRE_LOCK" ]; then echo "firing_now"; return; fi
  if [ -f "$SNOOZE_FILE" ]; then
    local until_epoch now_epoch
    until_epoch=$(cat "$SNOOZE_FILE" 2>/dev/null)
    now_epoch=$(date +%s)
    if [ -n "$until_epoch" ] && [ "$until_epoch" -gt "$now_epoch" ]; then
      echo "snoozed|$((until_epoch - now_epoch))"
      return
    else
      # Expired snooze
      rm -f "$SNOOZE_FILE"
    fi
  fi
  if [ -f "$CANCEL_LOCK" ]; then echo "cancel_next"; return; fi
  echo "active"
}

# iTerm per-tab state (from original kig)
set_tab_var() {
  local name="$1" value="$2"
  local b64
  b64=$(printf '%s' "$value" | base64 | tr -d '\n')
  printf '\e]1337;SetUserVar=%s=%s\a' "$name" "$b64"
}

tab_status() {
  osascript <<'EOF' 2>/dev/null
tell application "iTerm"
  try
    set v to variable named "user.keepitgoing" of current session of current tab of current window
    if v is "" then return "on (default)"
    return v
  on error
    return "on (default)"
  end try
end tell
EOF
}

print_status() {
  echo "${B}KeepItGoing status${N}"
  echo ""
  # Process
  if pgrep -fq "KeepItGoing-ClaudeChat"; then
    echo "  ${G}✓${N} applet running"
  else
    echo "  ${R}✗${N} applet NOT running  ${D}(run: open ~/GitRepos/KeepItGoing/dist/KeepItGoing-ClaudeChat.app)${N}"
  fi

  # Control state
  local ctrl; ctrl=$(get_control_state)
  case "$ctrl" in
    paused)
      echo "  ${Y}⏸${N}  globally PAUSED  ${D}(kig resume to continue)${N}" ;;
    firing_now)
      echo "  ${B}⚡${N} fire-now lock set — will fire on next poll" ;;
    snoozed*)
      local snz_left=${ctrl#snoozed|}
      echo "  ${Y}💤${N} snoozed for $(fmt_duration "$snz_left") more  ${D}(kig resume to clear)${N}" ;;
    cancel_next)
      echo "  ${Y}⊘${N}  next fire will be cancelled (one-shot)" ;;
    active)
      echo "  ${G}●${N} active" ;;
  esac

  # Countdown
  local cd; cd=$(compute_countdown)
  case "$cd" in
    nolog)
      echo "  ${D}no log yet${N}" ;;
    unknown)
      echo "  ${D}countdown: unknown (no recent cooldown/send in log)${N}" ;;
    sent*)
      local sent_ts=${cd#sent|}
      echo "  last fire: ${G}$sent_ts${N}" ;;
    cooldown*)
      IFS='|' read -r _ remaining required mode <<< "$cd"
      if [ "$remaining" -le 0 ]; then
        echo "  ${G}→ ready to fire any tick now${N}  ${D}(mode=$mode, cooldown=$(fmt_duration "$required"))${N}"
      else
        echo "  ${B}⏱${N}  next fire in ~$(fmt_duration "$remaining")  ${D}(mode=$mode, cooldown=$(fmt_duration "$required"))${N}"
      fi ;;
  esac

  # Classifier profile
  local cfg="$HOME/.claude/hooks/keepitgoing-config.json"
  if [ -f "$cfg" ]; then
    local profile
    profile=$(python3 -c "import json; print(json.load(open('$cfg')).get('classifier_profile', 'haiku'))" 2>/dev/null || echo "haiku")
    echo "  classifier: ${B}$profile${N}"
  else
    echo "  classifier: ${D}haiku (default)${N}"
  fi

  # This tab
  local ts; ts=$(tab_status 2>/dev/null || echo "unknown")
  echo "  this tab: $ts"
  echo ""
  echo "${D}commands: pause resume cancel snooze <dur> fire watch list log on off${N}"
}

cmd="${1:-status}"

case "$cmd" in
  "" | status)
    print_status
    ;;
  watch)
    while true; do
      clear
      print_status
      echo ""
      echo "${D}Ctrl+C to exit${N}"
      sleep 1
    done
    ;;
  pause)
    touch "$PAUSE_LOCK"
    rm -f "$FIRE_LOCK"
    echo "${Y}⏸  KeepItGoing PAUSED${N} globally. All sessions will be skipped until 'kig resume'."
    ;;
  resume | unpause)
    rm -f "$PAUSE_LOCK" "$SNOOZE_FILE" "$CANCEL_LOCK"
    echo "${G}▶  KeepItGoing resumed.${N}"
    ;;
  cancel)
    touch "$CANCEL_LOCK"
    echo "${Y}⊘  Next fire will be cancelled.${N} (one-shot; normal cadence resumes after)"
    ;;
  snooze)
    shift
    dur="${1:-}"
    if [ -z "$dur" ]; then
      echo "usage: kig snooze <duration>  (e.g. 5m, 30s, 1h)" >&2
      exit 1
    fi
    secs=$(parse_duration "$dur")
    until_epoch=$(($(date +%s) + secs))
    echo "$until_epoch" > "$SNOOZE_FILE"
    rm -f "$FIRE_LOCK"
    echo "${Y}💤 Snoozed for $(fmt_duration "$secs").${N} Will auto-resume at $(date -r "$until_epoch" '+%H:%M:%S')."
    ;;
  fire | now)
    touch "$FIRE_LOCK"
    rm -f "$PAUSE_LOCK" "$CANCEL_LOCK" "$SNOOZE_FILE"
    echo "${B}⚡ Will fire on next poll${N} (within ~30s)."
    ;;
  edit)
    OVERRIDE_FILE="$STATE_DIR/override-prompt.txt"
    # Seed with current pending (preview) if empty
    if [ ! -s "$OVERRIDE_FILE" ]; then
      # Try to generate a preview of what would fire next
      cwd=$(osascript <<'EOF' 2>/dev/null
tell application "iTerm"
  tell current session of current tab of current window
    try
      return variable "session.path"
    on error
      return ""
    end try
  end tell
end tell
EOF
)
      if [ -n "$cwd" ]; then
        python3 ~/.claude/hooks/scripts/keepitgoing-generate.py --cwd "$cwd" 2>/dev/null > "$OVERRIDE_FILE" || true
      fi
      echo "# Edit the prompt below — it will be sent verbatim on the next KIG fire." > "$OVERRIDE_FILE.hdr"
      echo "# Leave empty or delete the file to cancel the override." >> "$OVERRIDE_FILE.hdr"
      echo "" >> "$OVERRIDE_FILE.hdr"
      cat "$OVERRIDE_FILE" >> "$OVERRIDE_FILE.hdr" 2>/dev/null || true
      mv "$OVERRIDE_FILE.hdr" "$OVERRIDE_FILE"
    fi
    "${EDITOR:-nano}" "$OVERRIDE_FILE"
    # Strip comment lines starting with #
    if [ -f "$OVERRIDE_FILE" ]; then
      grep -v '^#' "$OVERRIDE_FILE" > "$OVERRIDE_FILE.tmp" && mv "$OVERRIDE_FILE.tmp" "$OVERRIDE_FILE"
      if [ -s "$OVERRIDE_FILE" ]; then
        echo "${G}✓${N} Override queued. Next fire will use this prompt."
        echo "${D}Preview (first 200 chars):${N}"
        head -c 200 "$OVERRIDE_FILE"; echo
      else
        rm -f "$OVERRIDE_FILE"
        echo "${Y}⊘${N} Override file empty — no override queued."
      fi
    fi
    ;;
  model)
    CONFIG_FILE="$HOME/.claude/hooks/keepitgoing-config.json"
    mkdir -p "$(dirname "$CONFIG_FILE")"
    shift
    arg="${1:-}"
    case "$arg" in
      "")
        # Show current
        if [ -f "$CONFIG_FILE" ]; then
          current=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('classifier_profile', 'haiku'))" 2>/dev/null || echo "haiku")
        else
          current="haiku (default — no config)"
        fi
        echo "${B}Current classifier profile:${N} $current"
        echo ""
        python3 "$HOME/.claude/hooks/scripts/keepitgoing-classify.py" --list-profiles
        ;;
      list)
        python3 "$HOME/.claude/hooks/scripts/keepitgoing-classify.py" --list-profiles
        ;;
      haiku|sonnet|opus|minimax-highspeed|minimax)
        python3 -c "
import json, pathlib
p = pathlib.Path('$CONFIG_FILE')
cfg = {}
if p.exists():
    try: cfg = json.loads(p.read_text())
    except Exception: pass
cfg['classifier_profile'] = '$arg'
p.parent.mkdir(parents=True, exist_ok=True)
p.write_text(json.dumps(cfg, indent=2))
print(f'${G}✓${N} classifier profile set to: $arg')
"
        echo ""
        echo "${D}Smoke-testing new profile with a canned classify...${N}"
        smoke_out=$(echo "Done with task. What next?" | \
          timeout 40 python3 "$HOME/.claude/hooks/scripts/keepitgoing-classify.py" --stdin --session kig-model-test 2>/dev/null)
        if [ -n "$smoke_out" ]; then
          echo "$smoke_out" | python3 -c "import json,sys; d=json.load(sys.stdin); print(f\"  ${G}✓${N} state={d.get('state')} elapsed={d.get('elapsed_ms','?')}ms model={d.get('classifier_model')}\")" 2>/dev/null || \
            echo "  ${Y}⚠${N} smoke test returned non-JSON"
        else
          echo "  ${Y}⚠${N} smoke test returned no output (API unreachable?)"
        fi
        ;;
      *)
        echo "kig model: unknown profile '$arg'" >&2
        echo "try: kig model list" >&2
        exit 1
        ;;
    esac
    ;;
  unstuck)
    shift
    # Capture last N lines of focused iTerm session, pipe to unstuck script
    TMP_CTX="$STATE_DIR/unstuck-context-$$.txt"
    osascript 2>/dev/null <<EOF > "$TMP_CTX"
tell application "iTerm"
  try
    set sessionContents to contents of current session of current tab of current window
    return sessionContents
  on error
    return ""
  end try
end tell
EOF
    if [ ! -s "$TMP_CTX" ]; then
      echo "${R}✗${N} Could not capture iTerm session contents. Is iTerm focused on a Claude tab?" >&2
      rm -f "$TMP_CTX"
      exit 1
    fi
    # Keep only last 120 non-blank lines (like the classifier does)
    grep -v '^[[:space:]]*$' "$TMP_CTX" | tail -120 > "$TMP_CTX.trimmed"
    mv "$TMP_CTX.trimmed" "$TMP_CTX"
    echo "${D}Context: $(wc -l < "$TMP_CTX") lines / $(wc -c < "$TMP_CTX") chars${N}"
    echo "${B}⚡ Escalating to Claude (this may take 30-120s)...${N}"
    # Pass through all remaining args (--dry-run, --force, --model, etc.)
    NUDGE=$(python3 "$HOME/.claude/hooks/scripts/keepitgoing-unstuck.py" --input-file "$TMP_CTX" "$@" 2>&1 1>&3 3>&-)
    status=$?
    # Actually we need stdout (the nudge) separately from stderr; redo:
    python3 "$HOME/.claude/hooks/scripts/keepitgoing-unstuck.py" --input-file "$TMP_CTX" "$@" > "$TMP_CTX.out" 2> "$TMP_CTX.err"
    status=$?
    if [ "$status" = 0 ]; then
      if grep -q '"dry_run": true' "$TMP_CTX.out" 2>/dev/null; then
        echo "${Y}--- DRY RUN ---${N}"
        cat "$TMP_CTX.out"
      else
        echo "${G}--- Strategic nudge from Claude ---${N}"
        cat "$TMP_CTX.out"
        echo ""
        echo "${G}--------------------------------${N}"
        echo ""
        echo "${D}$(cat "$TMP_CTX.err")${N}"
        # Queue the nudge as the next KIG fire so it lands in the stuck session
        cp "$TMP_CTX.out" "$STATE_DIR/override-prompt.txt"
        touch "$STATE_DIR/fire-now.lock"
        echo "${B}✓${N} Nudge queued as the next KIG fire (will land in the focused Claude tab within ~30s)."
        echo "  To abort: ${D}kig cancel${N}"
      fi
    else
      echo "${R}✗${N} Escalation failed (exit $status):"
      cat "$TMP_CTX.err" >&2
    fi
    rm -f "$TMP_CTX" "$TMP_CTX.out" "$TMP_CTX.err"
    exit "$status"
    ;;
  budget)
    shift
    sub="${1:-show}"
    CFG="$HOME/.claude/hooks/keepitgoing-config.json"
    mkdir -p "$(dirname "$CFG")"
    case "$sub" in
      show | "")
        python3 "$HOME/.claude/hooks/scripts/keepitgoing-unstuck.py" --budget
        if [ -f "$CFG" ]; then
          model=$(python3 -c "import json; print(json.load(open('$CFG')).get('escalation_model', 'opus'))" 2>/dev/null || echo opus)
          echo "  escalation model: $model"
        fi
        ;;
      set)
        dur="${2:-}"
        if [ -z "$dur" ]; then
          echo "usage: kig budget set <duration>  (e.g. 6h, 4h, 30m)" >&2
          exit 1
        fi
        secs=$(parse_duration "$dur")
        python3 -c "
import json, pathlib
p = pathlib.Path('$CFG')
cfg = json.loads(p.read_text()) if p.exists() else {}
cfg['claude_daily_budget_sec'] = $secs
p.parent.mkdir(parents=True, exist_ok=True)
p.write_text(json.dumps(cfg, indent=2))
print('${G}✓${N} claude_daily_budget_sec = $secs ($(printf %s "$dur"))')
"
        ;;
      model)
        m="${2:-}"
        case "$m" in
          opus|sonnet|haiku)
            python3 -c "
import json, pathlib
p = pathlib.Path('$CFG')
cfg = json.loads(p.read_text()) if p.exists() else {}
cfg['escalation_model'] = '$m'
p.parent.mkdir(parents=True, exist_ok=True)
p.write_text(json.dumps(cfg, indent=2))
print('${G}✓${N} escalation_model = $m')
"
            ;;
          *)
            echo "kig budget model: pick opus, sonnet, or haiku" >&2
            exit 1
            ;;
        esac
        ;;
      *)
        echo "kig budget: unknown subcommand '$sub'" >&2
        echo "try: kig budget | kig budget set <dur> | kig budget model <m>" >&2
        exit 1
        ;;
    esac
    ;;
  escalations)
    LOG="$HOME/.claude/hooks/state/kig-escalations.jsonl"
    if [ ! -f "$LOG" ]; then
      echo "${D}No escalations logged yet. Trigger one with: kig unstuck${N}"
      exit 0
    fi
    echo "${B}Recent escalations:${N}"
    tail -20 "$LOG" | python3 -c "
import json, sys
for line in sys.stdin:
    try:
        e = json.loads(line)
        print(f\"  {e['at']}  model={e['model']:<8}  elapsed={e['elapsed_sec']}s  \" + e.get('nudge_preview', '')[:80])
    except Exception:
        pass
"
    ;;
  preview)
    cwd=$(osascript <<'EOF' 2>/dev/null
tell application "iTerm"
  tell current session of current tab of current window
    try
      return variable "session.path"
    on error
      return ""
    end try
  end tell
end tell
EOF
)
    if [ -z "$cwd" ]; then cwd="$HOME"; fi
    echo "${D}cwd: $cwd${N}"
    echo "${B}Preview of next-generated prompt:${N}"
    python3 ~/.claude/hooks/scripts/keepitgoing-generate.py --cwd "$cwd" 2>&1
    ;;
  on)
    set_tab_var keepitgoing on
    echo "kig: ON for this tab"
    ;;
  off)
    set_tab_var keepitgoing off
    echo "kig: OFF for this tab"
    ;;
  list)
    osascript <<'EOF' 2>/dev/null
tell application "iTerm"
  set out to ""
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        set sn to name of s
        if sn contains "Claude" or sn contains "(python" then
          try
            set v to variable named "user.keepitgoing" of s
            if v is "" then set v to "on (default)"
          on error
            set v to "on (default)"
          end try
          set out to out & v & "  ::  " & sn & linefeed
        end if
      end repeat
    end repeat
  end repeat
  return out
end tell
EOF
    ;;
  log | tail)
    exec tail -f "$LOG_FILE"
    ;;
  help | --help | -h)
    sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *)
    echo "kig: unknown command '$cmd'" >&2
    echo "try: kig help" >&2
    exit 1
    ;;
esac
